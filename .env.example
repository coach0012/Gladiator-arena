# Server Configuration
PORT=3001
NODE_ENV=development
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gladiator_arena?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 0G Network Configuration (0G Mainnet — Aristotle, chain ID 16661)
OG_RPC_URL=https://evmrpc.0g.ai
OG_CHAIN_ID=16661
OG_INDEXER_URL=https://indexer-storage-turbo.0g.ai
# Private key used by the backend to sign 0G Storage uploads (fund this wallet with 0G tokens)
OG_STORAGE_PRIVATE_KEY=your-storage-wallet-private-key

# Contract Addresses (deploy on 0G Network)
ARENA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AGENT_NFT_CONTRACT=0x0000000000000000000000000000000000000000
BATTLE_CONTRACT=0x0000000000000000000000000000000000000000

# AI Configuration (for agent generation)
# AI providers for agent generation — set at least one.
# If both are set, Anthropic is tried first, OpenRouter is the fallback.
ANTHROPIC_API_KEY=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
OPENROUTER_API_KEY=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

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Rate Limiting
